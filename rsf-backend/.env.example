# ─── SERVEUR ───────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── BASE DE DONNÉES ────────────────────────────────────────────────────
# SQLite (par défaut, aucune installation requise)
DB_DIALECT=sqlite
DB_STORAGE=./database/rsf.sqlite

# MySQL / MariaDB (décommentez pour utiliser MySQL)
# DB_DIALECT=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_NAME=rsf_db
# DB_USER=root
# DB_PASS=votre_mot_de_passe

# PostgreSQL (décommentez pour utiliser PostgreSQL)
# DB_DIALECT=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=rsf_db
# DB_USER=postgres
# DB_PASS=votre_mot_de_passe

# ─── JWT ────────────────────────────────────────────────────────────────
JWT_SECRET=changez_ce_secret_tres_long_et_securise_en_production
JWT_EXPIRES_IN=7d

# ─── ADMIN PAR DÉFAUT ───────────────────────────────────────────────────
ADMIN_EMAIL=admin@reseau-solidarite-france.fr
ADMIN_PASSWORD=Admin@RSF2025!
ADMIN_NAME=TODEDJRAPOU Aimé

# ─── CORS ───────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500
