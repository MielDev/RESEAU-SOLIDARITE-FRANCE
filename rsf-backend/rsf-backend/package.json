{
  "name": "rsf-backend",
  "version": "1.0.0",
  "description": "Backend API - Réseau Solidarité France",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:check": "node scripts/checkDatabase.js",
